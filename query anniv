WITH cte AS (
    SELECT
        issdt,
        TRY_CONVERT(date, CAST(issdt AS varchar(8)), 112) AS dt
    FROM tr_dt
)

SELECT
    issdt,

    CASE
        WHEN DATEADD(YEAR, DATEDIFF(YEAR, dt, GETDATE()), dt) > GETDATE()
        THEN DATEADD(YEAR, DATEDIFF(YEAR, dt, GETDATE()) - 1, dt)
        ELSE DATEADD(YEAR, DATEDIFF(YEAR, dt, GETDATE()), dt)
    END AS last_anniv,

    CASE
        WHEN DATEADD(YEAR, DATEDIFF(YEAR, dt, GETDATE()), dt) <= GETDATE()
        THEN DATEADD(YEAR, DATEDIFF(YEAR, dt, GETDATE()) + 1, dt)
        ELSE DATEADD(YEAR, DATEDIFF(YEAR, dt, GETDATE()), dt)
    END AS next_anniv

FROM cte
WHERE dt IS NOT NULL;