SELECT
    t.issdt,

    CASE
        WHEN DATEADD(YEAR,
                     YEAR(GETDATE()) - YEAR(x.dt),
                     x.dt) <= CAST(GETDATE() AS DATE)
        THEN DATEADD(YEAR,
                     YEAR(GETDATE()) - YEAR(x.dt),
                     x.dt)

        ELSE DATEADD(YEAR,
                     YEAR(GETDATE()) - YEAR(x.dt) - 1,
                     x.dt)
    END AS last_anniv,

    CASE
        WHEN DATEADD(YEAR,
                     YEAR(GETDATE()) - YEAR(x.dt),
                     x.dt) > CAST(GETDATE() AS DATE)
        THEN DATEADD(YEAR,
                     YEAR(GETDATE()) - YEAR(x.dt),
                     x.dt)

        ELSE DATEADD(YEAR,
                     YEAR(GETDATE()) - YEAR(x.dt) + 1,
                     x.dt)
    END AS next_anniv

FROM tr_dt t

CROSS APPLY (
    SELECT TRY_CONVERT(date, CAST(t.issdt AS char(8))) AS dt
) x

WHERE x.dt IS NOT NULL;