DECLARE @periode VARCHAR(20)
DECLARE @html NVARCHAR(MAX)

-- Periode otomatis dari tanggal saat query dijalankan
SET @periode = FORMAT(GETDATE(),'MMM yyyy')

SET @html =
'<html>
<body>
<h3>Estimation AP Periode ' + @periode + '</h3>

<table border="1" cellpadding="5" cellspacing="0" style="border-collapse:collapse;">
<tr style="background-color:#f2f2f2;font-weight:bold;">
    <td>CHANNEL</td>
    <td>APE</td>
    <td>STU</td>
    <td>TOTAL APE</td>
</tr>' +

(
SELECT 
    '<tr>
        <td>' + channel + '</td>
        <td align="right">' + CAST(SUM(ape) AS VARCHAR) + '</td>
        <td align="right">' + CAST(SUM(stu) AS VARCHAR) + '</td>
        <td align="right">' + CAST(SUM(ape)+SUM(stu) AS VARCHAR) + '</td>
    </tr>'
FROM testing
GROUP BY channel
FOR XML PATH(''), TYPE
).value('.', 'NVARCHAR(MAX)')

+ '</table>
</body>
</html>'

SELECT @html AS bodymail